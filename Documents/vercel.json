{
    "version": 2,
    "builds": [
        {
            "src": "backend/api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "astrologer/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "backend/api/index.js"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "backend/api/index.js"
        },
        {
            "source": "/astrologer/(.*)",
            "destination": "/astrologer/$1"
        },
        {
            "source": "/astrologer",
            "destination": "/astrologer/index.html"
        },
        {
            "source": "/astrologer/(.*)",
            "destination": "/astrologer/index.html"
        },
        {
            "source": "/((?!api|uploads|astrologer).*)",
            "destination": "/frontend/$1"
        },
        {
            "source": "/((?!api|uploads|astrologer).*)",
            "destination": "/frontend/index.html"
        }
    ]
}